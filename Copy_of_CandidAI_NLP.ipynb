        "import re\n",
        "import string\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "QXOpXCBOS_Vz"
      },
      "outputs": [],
      "source": [
        "def clean_text(text):\n",
        "  if text is None: return \"\"\n",
        "  text = str(text).lower()\n",
        "  text = re.sub(r'<[^>]*>', '', text)\n",
        "  text = re.sub(r'http\\S+|www\\S+', '', text)\n",
        "  text = text.translate(str.maketrans('', '', string.punctuation))\n",
        "  text = re.sub(r'\\d+', '', text)\n",
        "  text = re.sub(r'\\s+', ' ', text).strip()\n",
        "  return text"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "combined_dataset = concatenate_datasets([hate_relabeled, racial_relabeled])\n",
        "\n",
        "split_dataset = combined_dataset.train_test_split(test_size=0.2, seed=42)\n",
        "\n",
        "train_dataset = split_dataset[\"train\"].shuffle(seed=42).select(range(5000))\n",
        "test_dataset = split_dataset[\"test\"].shuffle(seed=42).select(range(1000))"
      ],
